{
  "name": "ClubCRM",
  "dockerComposeFile": [
    "../infra/docker-compose.yml",
    "docker-compose.devcontainer.yml",
    "docker-compose.ports.yml"
  ],
  "initializeCommand": [
    "docker",
    "run",
    "--rm",
    "-v",
    "${localWorkspaceFolder}:/workspace",
    "-v",
    "/var/run/docker.sock:/var/run/docker.sock",
    "-w",
    "/workspace",
    "-e",
    "WORKSPACE_FOLDER=/workspace",
    "-e",
    "PORT_PROBE_IMAGE=node:22-alpine",
    "node:22-alpine",
    "node",
    ".devcontainer/prepare-ports.mjs"
  ],
  "service": "workspace",
  "runServices": ["workspace", "postgres", "mongodb", "redis", "kafka", "api", "web"],
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "forwardPorts": [3000, 8000, 5432, 27017, 6379, 9092],
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "postCreateCommand": "python3 ./scripts/bootstrap.py"
}
