# Local monitor-web against the currently live monitor-api on DemoControlPlaneServer.
# Verified reachable from this repo environment on April 18, 2026.

MONITOR_WEB_PORT=3001
MONITOR_API_BASE_URL=http://192.168.139.213:8010
NEXT_PUBLIC_MONITOR_API_BASE_URL=http://192.168.139.213:8010
NEXT_PUBLIC_MONITOR_WS_URL=ws://192.168.139.213:8010/ws/stream
NEXT_PUBLIC_CLUBCRM_DEMO_URL=http://clubcrm.local/demo/failover
CLUBCRM_DEMO_URL=http://clubcrm.local/demo/failover

# Read-only dashboard rendering works without a valid admin token.
# Set the real token if you want local control actions to forward to the live monitor-api.
MONITOR_ADMIN_TOKEN=replace-with-live-monitor-admin-token
CONTROL_MODE_PASSWORD=replace-with-control-mode-password
