# Full local monitor-api + monitor-web wired for the live networking environment.
# Use this when you need to work on backend connectors locally, not just the dashboard.
#
# Important: the live VMs must be able to reach your local monitor-api for heartbeat-based
# connectors to work in real time. In practice that usually means either:
# - exposing your local port 8010 through a tunnel or reachable LAN/VPN address, then
#   updating the guest agents' MONITOR_API_BASE_URL to point to your machine
# - or temporarily testing connector work against pull-based data sources only
#
# Verified live endpoints from this repo environment on April 18, 2026:
# - live monitor host: http://192.168.139.213:8010
# - live ClubCRM health page: http://clubcrm.local/system/health
# - live ClubCRM failover demo: http://clubcrm.local/demo/failover

MONITOR_API_HOST=0.0.0.0
MONITOR_API_PORT=8010
MONITOR_API_BASE_URL=http://localhost:8010
MONITOR_WEB_PORT=3001
NEXT_PUBLIC_MONITOR_API_BASE_URL=http://localhost:8010
NEXT_PUBLIC_MONITOR_WS_URL=ws://localhost:8010/ws/stream
NEXT_PUBLIC_CLUBCRM_DEMO_URL=http://clubcrm.local/demo/failover
CLUBCRM_DEMO_URL=http://clubcrm.local/demo/failover

MONITOR_ADMIN_TOKEN=replace-with-live-monitor-admin-token
CONTROL_MODE_PASSWORD=replace-with-control-mode-password
# Extend these lists as you add new live servers.
MONITOR_TARGET_VMS=Server1,Server2,Server3
MONITOR_AGENT_TOKENS=Server1:replace-server1-token,Server2:replace-server2-token,Server3:replace-server3-token

MONITOR_SYNTHETIC_TARGET_URL=http://clubcrm.local/system/health
MONITOR_SYNTHETIC_INTERVAL_SECONDS=2
MONITOR_SYNTHETIC_TIMEOUT_SECONDS=2
MONITOR_HISTORY_LIMIT=300
MONITOR_EVENT_LIMIT=120
MONITOR_STALE_AFTER_SECONDS=4
MONITOR_LATENCY_SPIKE_MS=500

# Set these when your local monitor-api should control the live OrbStack host through SSH.
MONITOR_ORBSTACK_SSH_HOST=
MONITOR_ORBSTACK_SSH_USER=
MONITOR_ORBSTACK_SSH_PORT=22
MONITOR_ORBSTACK_SSH_IDENTITY_FILE=
MONITOR_ORBSTACK_REMOTE_WRAPPER=/usr/local/bin/clubcrm-monitor-orbstack
MONITOR_ORBSTACK_POLL_INTERVAL_SECONDS=5

# Leave blank for live kubectl access; set a JSON path to rehearse against a stable snapshot instead.
MONITOR_K8S_SNAPSHOT_FILE=
MONITOR_K8S_POLL_INTERVAL_SECONDS=5
