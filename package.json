{
  "name": "clubcrm",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "bootstrap": "python3 ./scripts/bootstrap.py",
    "verify": "pnpm format:check && pnpm lint && pnpm build",
    "dev": "pnpm dev:api & pnpm dev:web",
    "dev:web": "python3 ./scripts/dev_web.py",
    "dev:api": "python3 ./scripts/dev_api.py",
    "build": "pnpm build:web && pnpm check:api",
    "build:web": "bash ./scripts/build-web.sh",
    "format": "pnpm format:prettier && pnpm format:api",
    "format:check": "pnpm format:prettier:check && pnpm format:api:check",
    "format:prettier": "prettier --write .",
    "format:prettier:check": "prettier --check .",
    "format:api": "bash ./scripts/format-api.sh",
    "format:api:check": "bash ./scripts/format-api.sh --check",
    "lint": "pnpm lint:prettier && pnpm lint:web && pnpm lint:api && pnpm check:api",
    "lint:prettier": "prettier --check .",
    "lint:web": "pnpm --filter web exec eslint . --max-warnings=0",
    "lint:api": "bash ./scripts/lint-api.sh",
    "check:api": "bash ./scripts/check-api.sh"
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
