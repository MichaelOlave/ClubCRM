# Environment variables for ClubCRM application
API_APP_TITLE="ClubCRM API"
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://api:8000
WEB_API_PUBLIC_BASE_URL=http://localhost:8000

# Local Bypass for Auth (for development purposes only)
IS_AUTH_BYPASS=true

# Auth0 configuration
AUTH0_APP_NAME=your-auth0-app-name
AUTH0_DOMAIN=your-auth0-domain
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_SCOPES="openid profile email"
AUTH_SESSION_COOKIE_NAME=clubcrm_session
AUTH_SESSION_MAX_AGE_SECONDS=43200
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
AUTH_CSRF_COOKIE_NAME=clubcrm_csrf
AUTH_CSRF_HEADER_NAME=X-CSRF-Token
AUTH_LOGIN_SUCCESS_URL=http://localhost:3000/dashboard
AUTH_LOGOUT_REDIRECT_URL=http://localhost:3000/login

# PostgreSQL configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=clubcrm
POSTGRES_USER=clubcrm
POSTGRES_PASSWORD=clubcrm
DATABASE_URL=postgresql://clubcrm:clubcrm@postgres:5432/clubcrm

# MongoDB configuration
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DB=clubcrm
MONGODB_URL=mongodb://mongodb:27017/clubcrm

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# Kafka configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_NODE_ID=1
KAFKA_PROCESS_ROLES=broker,controller
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093
KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true

# Companion monitoring stack (optional, separate from the main ClubCRM apps)
MONITOR_API_TITLE="ClubCRM Monitoring API"
MONITOR_API_HOST=0.0.0.0
MONITOR_API_PORT=8010
MONITOR_API_BASE_URL=http://localhost:8010
NEXT_PUBLIC_MONITOR_API_BASE_URL=http://localhost:8010
NEXT_PUBLIC_MONITOR_WS_URL=ws://localhost:8010/ws/stream
NEXT_PUBLIC_CLUBCRM_DEMO_URL=http://localhost:3000/demo/failover
MONITOR_WEB_PORT=3001
MONITOR_ADMIN_TOKEN=monitor-admin-token
# Set these to the real demo VM names and per-VM tokens, for example:
# MONITOR_AGENT_TOKENS=Server1:monitor-agent-server1,Server2:monitor-agent-server2,Server3:monitor-agent-server3
MONITOR_AGENT_TOKENS=vm1:monitor-agent-vm1,vm2:monitor-agent-vm2,vm3:monitor-agent-vm3
# Set this to the real OrbStack machine names you want to monitor.
MONITOR_TARGET_VMS=vm1,vm2,vm3
MONITOR_SYNTHETIC_TARGET_URL=http://localhost:8000/health
MONITOR_SYNTHETIC_INTERVAL_SECONDS=2
MONITOR_SYNTHETIC_TIMEOUT_SECONDS=2
MONITOR_HISTORY_LIMIT=300
MONITOR_EVENT_LIMIT=120
MONITOR_STALE_AFTER_SECONDS=4
MONITOR_LATENCY_SPIKE_MS=500
# Leave these blank when monitor-api runs on the same Mac as OrbStack. It will use local `orbctl`.
MONITOR_ORBSTACK_SSH_HOST=
MONITOR_ORBSTACK_SSH_USER=
MONITOR_ORBSTACK_SSH_PORT=22
MONITOR_ORBSTACK_SSH_IDENTITY_FILE=
MONITOR_ORBSTACK_REMOTE_WRAPPER=/usr/local/bin/clubcrm-monitor-orbstack
MONITOR_ORBSTACK_POLL_INTERVAL_SECONDS=5
MONITOR_K8S_SNAPSHOT_FILE=
MONITOR_K8S_POLL_INTERVAL_SECONDS=5
